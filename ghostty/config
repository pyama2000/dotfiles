command = /run/current-system/sw/bin/fish --login --command /etc/profiles/per-user/takahiko-yamashita/bin/tmux attach || /etc/profiles/per-user/takahiko-yamashita/bin/tmux

theme = Kanagawa Wave
font-family = Explex35 Console NF
font-feature = -dlig
font-size = 12

window-padding-x = 10
window-padding-y = 5
window-padding-balance = true
window-theme = ghostty
background-opacity = 0.75
macos-titlebar-style = hidden
quick-terminal-position = center
quick-terminal-screen = main
quick-terminal-animation-duration = 0
keybind = "global:cmd+shift+g=toggle_quick_terminal"
